  <!-- Modal -->
  <div class="modal-backdrop" id="modalBackdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-label="Cart">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <h3 style="margin:0">Your Cart</h3>
        <button class="ghost" id="closeModal" aria-label="Close cart">Close</button>
      </div>
      <div id="cartItems" style="margin-top:12px">
        <div class="cart-empty">Your cart is empty</div>
      </div>
      <div style="display:flex; justify-content:space-between; align-items:center; margin-top:12px;">
        <div class="muted">Subtotal</div>
        <div id="cartSubtotal" style="font-weight:800">$0</div>
      </div>
      <div style="margin-top:12px; display:flex; gap:8px;">
        <button class="btn" id="checkoutBtn">Checkout</button>
        <button class="ghost" id="clearCart">Clear</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite">Added to cart</div>

  <script>
    // Minimal interactive behavior
    (function(){
      const revealEls = document.querySelectorAll('.reveal');
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('show'); obs.unobserve(e.target) }
        });
      }, {threshold: 0.12});
      revealEls.forEach(el => obs.observe(el));

      // Mobile menu toggle (simple)
      const menuToggle = document.getElementById('menuToggle');
      menuToggle && menuToggle.addEventListener('click', () => {
        const nav = document.querySelector('.nav');
        if (nav.style.display === 'flex') {
          nav.style.display = '';
        } else {
          nav.style.display = 'flex';
          nav.style.flexDirection = 'column';
          nav.style.position = 'absolute';
          nav.style.right = '24px';
          nav.style.top = '72px';
          nav.style.background = 'rgba(255,255,255,0.95)';
          nav.style.padding = '12px';
          nav.style.borderRadius = '12px';
          nav.style.boxShadow = '0 12px 40px rgba(7,15,30,0.12)';
        }
      });

      // Cart functionality
      let cart = [];
      const cartCount = document.getElementById('cartCount');
      const openCart = document.getElementById('openCart');
      const modalBackdrop = document.getElementById('modalBackdrop');
      const closeModal = document.getElementById('closeModal');
      const cartItems = document.getElementById('cartItems');
      const cartSubtotal = document.getElementById('cartSubtotal');
      const checkoutBtn = document.getElementById('checkoutBtn');
      const clearCartBtn = document.getElementById('clearCart');
      const toast = document.getElementById('toast');

      function updateCartUI(){
        if (cart.length === 0) {
          cartItems.innerHTML = '<div class="cart-empty">Your cart is empty</div>';
          cartCount.style.display = 'none';
          cartCount.textContent = '0';
          cartSubtotal.textContent = '$0';
        } else {
          cartCount.style.display = 'flex';
          cartCount.textContent = cart.reduce((s,i) => s + i.qty, 0);
          cartItems.innerHTML = '';
          cart.forEach((it, idx) => {
            const node = document.createElement('div');
            node.className = 'cart-item';
            node.innerHTML = `
              <div style="width:56px;height:64px;border-radius:8px;background:linear-gradient(135deg, rgba(6,182,212,0.08), rgba(3,105,161,0.03)); display:flex;align-items:center;justify-content:center;">
                <div style="font-weight:800; color:var(--accent-1)">${it.name.split(' ')[0].slice(0,2)}</div>
              </div>
              <div style="flex:1">
                <div style="font-weight:700">${it.name}</div>
                <div class="muted small">Qty: ${it.qty}</div>
              </div>
              <div style="font-weight:800">$${(it.price * it.qty).toFixed(2)}</div>
            `;
            cartItems.appendChild(node);
          });
          const subtotal = cart.reduce((s,i)=>s + i.price * i.qty, 0);
          cartSubtotal.textContent = '$' + subtotal.toFixed(2);
        }
      }

      function showModal(show){
        modalBackdrop.style.display = show ? 'flex' : 'none';
        modalBackdrop.setAttribute('aria-hidden', show ? 'false' : 'true');
      }

      document.querySelectorAll('.add-to-cart').forEach(btn => {
        btn.addEventListener('click', () => {
          const name = btn.dataset.name || 'Bottle';
          const price = parseFloat(btn.dataset.price) || 0;
          const existing = cart.find(i=>i.name===name);
          if (existing) existing.qty += 1; else cart.push({name, price, qty:1});
          updateCartUI();
          // show toast
          toast.textContent = `${name} added to cart`;
          toast.style.display = 'block';
          setTimeout(()=> toast.style.display='none', 2200);
        });
      });

      openCart.addEventListener('click', ()=> showModal(true));
      closeModal.addEventListener('click', ()=> showModal(false));
      modalBackdrop.addEventListener('click', (e)=> { if (e.target === modalBackdrop) showModal(false); });

      clearCartBtn.addEventListener('click', ()=> { cart = []; updateCartUI(); });

      checkoutBtn.addEventListener('click', ()=> {
        if (cart.length === 0) {
          toast.textContent = 'Your cart is empty';
          toast.style.display = 'block';
          setTimeout(()=> toast.style.display='none', 1800);
          return;
        }
        // simplistic checkout flow simulation
        toast.textContent = 'Checkout complete — thanks!';
        toast.style.display = 'block';
        setTimeout(()=> toast.style.display='none', 2000);
        cart = [];
        updateCartUI();
        showModal(false);
      });

      // subscription form
      const subscribeForm = document.getElementById('subscribeForm');
      subscribeForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        if (!email || !/^\S+@\S+\.\S+$/.test(email)) {
          toast.textContent = 'Enter a valid email';
          toast.style.display = 'block';
          setTimeout(()=> toast.style.display='none', 1600);
          return;
        }
        toast.textContent = 'Thanks! Check your inbox';
        toast.style.display = 'block';
        setTimeout(()=> toast.style.display='none', 2000);
        subscribeForm.reset();
      });

      // Load more - demonstration
      document.getElementById('loadMore').addEventListener('click', (e) => {
        e.target.textContent = 'No more items';
        e.target.disabled = true;
      });

      // Shop Now scroll
      document.getElementById('shopNow').addEventListener('click', () => {
        document.getElementById('products').scrollIntoView({behavior:'smooth'});
      });

      // Quick accessibility: close modal with Esc
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { showModal(false); }
      });

      // initial reveal run (for those on top)
      document.querySelectorAll('.reveal').forEach(el => {
        // allow intersection observer to handle, but if not visible, still show top content
        if (el.getBoundingClientRect().top < window.innerHeight * 0.6) el.classList.add('show');
      });

      // initial cart UI
      updateCartUI();

    })();
  </script>
</body>
