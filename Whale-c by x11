<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Whale C — Sustainable Water Bottles</title>
  <meta name="description" content="Whale C makes premium, sustainable, insulated water bottles inspired by the ocean. Durable, stylish, and eco-friendly." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg-1: #e6f3ff;
      --bg-2: #f6fff9;
      --accent-1: #0369a1;
      --accent-2: #06b6d4;
      --accent-3: #0ea5a4;
      --muted: #6b7280;
      --glass: rgba(255,255,255,0.55);
      --card-shadow: 0 8px 30px rgba(7,15,30,0.12);
      --radius: 14px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
      color:#06202a;
      background: linear-gradient(180deg,var(--bg-1),var(--bg-2));
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      -webkit-tap-highlight-color: transparent;
      overflow-y: auto;
    }

    /* Layout */
    .container{
      max-width:1200px;
      margin:0 auto;
      padding:28px;
    }

    header{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:18px;
      padding:18px 0;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      text-decoration:none;
      color:inherit;
    }
    .logo {
      width:58px;
      height:58px;
      border-radius:12px;
      background: linear-gradient(135deg,#06b6d4 0%, #0369a1 100%);
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow: 0 6px 20px rgba(3,105,161,0.18), inset 0 -6px 18px rgba(255,255,255,0.18);
      color:white;
      font-weight:800;
      font-family:Manrope, Inter;
    }

    .nav{
      display:flex;
      align-items:center;
      gap:18px;
    }
    .nav a{
      text-decoration:none;
      color:var(--muted);
      font-weight:600;
      padding:8px 12px;
      border-radius:10px;
      transition:all .18s ease;
    }
    .nav a:hover{
      color:var(--accent-1);
      transform:translateY(-2px);
      background: rgba(6,182,212,0.06);
    }

    .actions{display:flex; align-items:center; gap:12px;}

    .btn{
      background:linear-gradient(90deg,var(--accent-2),var(--accent-1));
      color:white;
      border:none;
      padding:10px 14px;
      border-radius:12px;
      font-weight:700;
      cursor:pointer;
      box-shadow: 0 8px 24px rgba(3,105,161,0.12);
      transition:transform .14s ease, box-shadow .14s ease, opacity .14s ease;
    }
    .btn:active{transform:translateY(1px)}
    .ghost{
      background:transparent;
      border:1px solid rgba(6,182,212,0.12);
      color:var(--accent-1);
      padding:8px 12px;
      border-radius:12px;
      font-weight:700;
      cursor:pointer;
    }

    /* Hero */
    .hero{
      display:grid;
      grid-template-columns:1fr 480px;
      gap:28px;
      align-items:center;
      padding:36px 0 10px;
    }
    @media (max-width:960px){
      .hero{grid-template-columns:1fr; padding:18px 0}
      header{padding:12px 0}
    }

    .hero-card{
      background: linear-gradient(180deg, rgba(255,255,255,0.7), rgba(255,255,255,0.55));
      border-radius:20px;
      padding:28px;
      box-shadow: var(--card-shadow);
      backdrop-filter: blur(8px);
    }

    .kicker{
      display:inline-flex;
      gap:10px;
      align-items:center;
      font-weight:700;
      padding:8px 12px;
      border-radius:999px;
      background:linear-gradient(90deg, rgba(6,182,212,0.12), rgba(3,105,161,0.08));
      color:var(--accent-1);
      font-size:14px;
      width:max-content;
    }
    .title{
      font-size:36px;
      line-height:1.03;
      margin:14px 0;
      font-weight:800;
      font-family:Manrope, Inter;
      color: #03303a;
    }
    .subtitle{
      color:var(--muted);
      font-size:16px;
      margin-bottom:20px;
    }

    .cta-row{display:flex; gap:12px; align-items:center; margin-top:8px;}
    .ghost-cta{padding:10px 14px; border-radius:12px; background:transparent; border:1px solid rgba(3,105,161,0.08)}
    .price-pill{
      margin-left:12px;
      background:linear-gradient(90deg,#ecfeff,#ffffff);
      padding:8px 12px;
      border-radius:12px;
      color:var(--accent-3);
      font-weight:800;
      box-shadow: 0 6px 18px rgba(6,182,212,0.06);
    }

    /* Whale art + product */
    .hero-art{
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
      height:420px;
      border-radius:20px;
      overflow:visible;
      padding:24px;
    }

    .ocean-wave{
      position:absolute;
      bottom:-20px;
      left:0;
      right:0;
      height:60px;
      background: linear-gradient(90deg, rgba(6,182,212,0.08), rgba(3,105,161,0.04));
      border-radius:40px;
      filter: blur(12px);
      transform: translateY(8px);
    }

    /* Whale SVG */
    .whale {
      width:320px;
      height:220px;
      transform-origin:center;
      animation: floaty 5.4s ease-in-out infinite;
      will-change:transform;
    }
    @keyframes floaty{
      0%{transform: translateY(0) rotate(-1deg)}
      50%{transform: translateY(-10px) rotate(1deg)}
      100%{transform: translateY(0) rotate(-1deg)}
    }

    /* Product cards */
    .products{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
      margin-top:28px;
    }
    @media (max-width:960px){
      .products{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width:640px){
      .products{grid-template-columns:1fr}
    }

    .card{
      background:linear-gradient(180deg, rgba(255,255,255,0.65), rgba(255,255,255,0.5));
      border-radius:16px;
      padding:18px;
      box-shadow: 0 10px 30px rgba(10,20,30,0.06);
      transition:transform .18s ease, box-shadow .18s ease;
      display:flex;
      gap:12px;
      align-items:center;
    }
    .card:hover{transform:translateY(-6px); box-shadow:0 20px 40px rgba(10,20,30,0.08)}
    .bottle-illustration{
      width:120px;
      height:120px;
      display:flex;
      align-items:center;
      justify-content:center;
      border-radius:12px;
      background:linear-gradient(135deg, rgba(255,255,255,0.45), rgba(6,182,212,0.04));
      flex-shrink:0;
      position:relative;
    }

    .bottle-svg{
      width:74px;
      height:120px;
      transform-origin:center;
      animation: bob 3s ease-in-out infinite;
    }
    @keyframes bob {
      0%{transform: translateY(0)}
      50%{transform: translateY(-6px)}
      100%{transform: translateY(0)}
    }

    .card-info{
      flex:1;
      display:flex;
      flex-direction:column;
      gap:6px;
    }
    .name{font-weight:800; font-size:16px}
    .meta{color:var(--muted); font-size:14px}
    .price{font-weight:800; color:var(--accent-1); margin-top:6px}
    .variant-dots{display:flex; gap:8px; margin-top:8px; align-items:center}
    .dot{width:18px; height:18px; border-radius:50%; border:2px solid rgba(255,255,255,0.6); box-shadow: 0 6px 16px rgba(3,105,161,0.08); cursor:pointer}
    .dot:focus{outline:2px solid rgba(6,182,212,0.18)}
    .add-row{display:flex; gap:8px; align-items:center; margin-top:10px}

    /* Features */
    .features{
      margin-top:48px;
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
    }
    @media (max-width:960px){
      .features{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width:640px){
      .features{grid-template-columns:1fr}
    }
    .feature{
      padding:18px;
      border-radius:12px;
      background:linear-gradient(180deg, rgba(255,255,255,0.85), rgba(255,255,255,0.7));
      box-shadow:0 10px 30px rgba(7,15,30,0.04);
    }
    .feature h4{margin:8px 0 6px}
    .feature p{color:var(--muted); font-size:14px; margin:0}

    /* Testimonial */
    .testimonial{
      margin-top:36px;
      padding:20px;
      border-radius:12px;
      background:linear-gradient(90deg, rgba(6,182,212,0.06), rgba(3,105,161,0.02));
      display:flex;
      gap:12px;
      align-items:center;
    }
    .avatar{
      width:56px;
      height:56px;
      border-radius:12px;
      background:linear-gradient(135deg,#ffffff,#e6f7ff);
      display:flex; align-items:center; justify-content:center;
      font-weight:800; color:var(--accent-1);
    }

    /* Pricing / subscribe */
    .subscribe{
      margin-top:28px;
      display:flex;
      gap:12px;
      align-items:center;
      justify-content:space-between;
      padding:16px;
      border-radius:12px;
      background:linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.9));
      box-shadow: var(--card-shadow);
    }
    .subscribe form{display:flex; gap:8px; align-items:center; width:100%}
    .input{
      background:#fff;
      padding:12px 14px;
      border-radius:10px;
      border:1px solid rgba(3,105,161,0.06);
      flex:1;
      font-weight:600;
    }

    /* Footer */
    footer{
      margin-top:48px;
      padding:28px 0 60px;
      color:var(--muted);
      display:flex;
      gap:18px;
      align-items:flex-start;
      justify-content:space-between;
      flex-wrap:wrap;
    }
    .foot-links{display:flex; gap:24px; flex-wrap:wrap}
    .small{font-size:13px}

    /* Mobile nav button */
    .mobile-toggle{
      display:none;
      background:transparent;
      border:none;
      padding:8px;
      border-radius:10px;
    }
    @media (max-width:960px){
      .nav{display:none}
      .mobile-toggle{display:inline-flex}
    }

    /* Cart modal / toast */
    .cart-bubble{
      position:relative;
      display:inline-block;
    }
    .cart-count{
      position:absolute;
      top:-6px; right:-6px;
      background:#ef4444;
      color:white;
      width:20px;height:20px;
      border-radius:999px;
      display:flex; align-items:center; justify-content:center;
      font-size:12px; font-weight:700;
      box-shadow:0 6px 18px rgba(234,88,12,0.12);
    }

    .modal-backdrop{
      position:fixed; inset:0; background: rgba(2,6,23,0.45); display:none; align-items:center; justify-content:center; z-index:60;
    }
    .modal{
      background:linear-gradient(180deg,#ffffff,#f8fdfd);
      width:420px;
      max-width:calc(100% - 48px);
      border-radius:14px;
      padding:18px;
      box-shadow: 0 30px 80px rgba(2,6,23,0.45);
    }
    .modal h3{margin:0 0 8px}
    .cart-item{display:flex; gap:12px; align-items:center; padding:10px 0; border-bottom:1px dashed rgba(3,105,161,0.06)}
    .cart-empty{color:var(--muted); padding:18px 0; text-align:center}

    /* Toast */
    .toast{
      position:fixed;
      right:18px;
      bottom:18px;
      background:linear-gradient(90deg,#06b6d4,#0369a1);
      color:white;
      padding:12px 16px;
      border-radius:12px;
      box-shadow:0 18px 50px rgba(3,105,161,0.18);
      display:none;
      z-index:80;
      font-weight:700;
    }

    /* subtle animations on reveal */
    .reveal{opacity:0; transform:translateY(8px); transition:all .7s cubic-bezier(.2,.9,.2,1)}
    .reveal.show{opacity:1; transform:none}
    /* tiny helper */
    .muted{color:var(--muted)}
  </style>
</head>
<body>
  <div class="container">
    <header>
      <a class="brand" href="#" aria-label="Whale C home">
        <div class="logo" aria-hidden="true">WC</div>
        <div>
          <div style="font-weight:800; font-family:Manrope, Inter; font-size:16px;">Whale C</div>
          <div class="small muted">Ocean-friendly hydration</div>
        </div>
      </a>

      <nav class="nav" aria-label="Main navigation">
        <a href="#products">Products</a>
        <a href="#features">Why Whale C</a>
        <a href="#sustainability">Sustainability</a>
        <a href="#contact">Contact</a>
      </nav>

      <div class="actions">
        <button class="mobile-toggle" id="menuToggle" aria-label="Toggle menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="#063241" stroke-width="1.6" stroke-linecap="round"></path>
          </svg>
        </button>

        <div class="cart-bubble">
          <button class="ghost" id="openCart" aria-label="Open cart">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="vertical-align:middle; margin-right:6px">
              <path d="M3 3h2l.4 2M7 13h10l3-8H6.4" stroke="#0369a1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="9" cy="20" r="1" fill="#0369a1"/><circle cx="18" cy="20" r="1" fill="#0369a1"/>
            </svg>
            Cart
          </button>
          <div class="cart-count" id="cartCount" aria-hidden="true" style="display:none">0</div>
        </div>

        <button class="btn" id="buyNow">Buy</button>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-card reveal" id="heroLeft">
          <div class="kicker">New — 2026 Edition</div>
          <h1 class="title">Sustainably cool. Ocean inspired.</h1>
          <p class="subtitle">Whale C bottles keep drinks cold for 48 hours and hot for 24. Recycled stainless steel, ocean-safe inks, and returns that fund marine cleanup.</p>

          <div class="cta-row">
            <button class="btn" id="shopNow">Shop Collection</button>
            <button class="ghost-cta ghost" id="learnMore">Learn More</button>
            <div class="price-pill">$29 – $42</div>
          </div>

          <div style="margin-top:18px; display:flex; gap:12px; align-items:center; color:var(--muted)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2v4M12 20v2M4.2 4.2l2.8 2.8M17 17l4 4M2 12h4M20 12h2M4.2 19.8l2.8-2.8" stroke="#06b6d4" stroke-width="1.4" stroke-linecap="round"/></svg>
            <div style="font-size:14px">Free shipping on orders over $60 • 30-day returns • 1% for the Ocean</div>
          </div>

          <div style="margin-top:20px">
            <div style="display:flex; gap:12px; align-items:center;">
              <div style="display:flex; gap:8px; align-items:center;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="flex-shrink:0"><path d="M20 6L9 17l-5-5" stroke="#10b981" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <div style="font-weight:700">Double-walled vacuum insulation</div>
              </div>
            </div>
          </div>
        </div>

        <div class="hero-art reveal" id="heroRight" aria-hidden="true">
          <div style="position:absolute; inset:-30px -20px -20px -20px; background:linear-gradient(135deg, rgba(3,105,161,0.06), rgba(6,182,212,0.03)); border-radius:20px; z-index:0"></div>

          <!-- Whale SVG -->
          <svg class="whale" viewBox="0 0 700 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Animated whale">
            <defs>
              <linearGradient id="g1" x1="0" x2="1">
                <stop offset="0" stop-color="#06b6d4"/>
                <stop offset="1" stop-color="#0369a1"/>
              </linearGradient>
              <linearGradient id="g2" x1="0" x2="1">
                <stop offset="0" stop-color="#bfefff"/>
                <stop offset="1" stop-color="#dff9ff"/>
              </linearGradient>
            </defs>

            <g transform="translate(60,80)">
              <path d="M120 160 C40 160 20 110 20 90 C20 40 120 40 220 40 C320 40 420 90 420 90 C460 120 380 160 320 160 C260 160 240 160 120 160 Z" fill="url(#g1)" opacity="0.98"/>
              <path d="M30 90 C90 60 150 52 220 52 C300 52 355 90 375 110" stroke="rgba(255,255,255,0.2)" stroke-width="6" fill="none"/>
              <ellipse cx="120" cy="90" rx="14" ry="12" fill="#083344"/>
              <path d="M405 98 C435 80 460 84 495 72" stroke="#0ea5a4" stroke-width="5" stroke-linecap="round" fill="none" opacity="0.5">
                <animate attributeName="d" dur="6s" repeatCount="indefinite"
                  values="M405 98 C435 80 460 84 495 72;
                          M405 98 C435 74 460 86 495 80;
                          M405 98 C435 80 460 84 495 72"/>
              </path>

              <!-- water bubbles -->
              <g opacity="0.85">
                <circle cx="360" cy="30" r="6" fill="rgba(255,255,255,0.8)" opacity="0.9">
                  <animate attributeName="cy" dur="5s" values="30;0;30" repeatCount="indefinite"/>
                </circle>
                <circle cx="390" cy="40" r="4" fill="rgba(255,255,255,0.8)">
                  <animate attributeName="cy" dur="4s" values="40;12;40" repeatCount="indefinite"/>
                </circle>
              </g>

              <!-- bottle preview -->
              <g transform="translate(180,40) scale(0.9)">
                <rect x="0" y="0" width="64" height="150" rx="14" fill="url(#g2)" stroke="#cceff6" stroke-width="2" />
                <rect x="14" y="-10" width="36" height="20" rx="8" fill="#0369a1" />
                <circle cx="32" cy="40" r="6" fill="#0369a1" opacity="0.8"/>
              </g>
            </g>
          </svg>

          <div class="ocean-wave"></div>
        </div>
      </section>

      <!-- Products -->
      <section id="products" style="margin-top:20px">
        <div style="display:flex; gap:12px; align-items:end; justify-content:space-between;">
          <div>
            <h2 style="margin:6px 0 0; font-family:Manrope, Inter">Our Bottles</h2>
            <div class="muted" style="font-size:14px">Designed for life — gym, office, waves.</div>
          </div>
          <div class="muted" style="font-size:14px">Sort by: <strong style="color:var(--accent-1)">Most popular</strong></div>
        </div>

        <div class="products" style="margin-top:18px">
          <!-- Card 1 -->
          <div class="card reveal">
            <div class="bottle-illustration">
              <!-- SVG Bottle Blue -->
              <svg class="bottle-svg" viewBox="0 0 80 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="b1" x1="0" x2="1">
                    <stop offset="0" stop-color="#e0fbff"/>
                    <stop offset="1" stop-color="#a5f3fc"/>
                  </linearGradient>
                </defs>
                <rect x="20" y="20" width="40" height="120" rx="14" fill="url(#b1)" stroke="#06b6d4" stroke-width="3"/>
                <rect x="26" y="2" width="28" height="24" rx="8" fill="#0369a1"/>
                <circle cx="40" cy="80" r="5" fill="#0369a1"/>
              </svg>
            </div>
            <div class="card-info">
              <div style="display:flex; align-items:center; justify-content:space-between;">
                <div>
                  <div class="name">Classic Ocean — 20oz</div>
                  <div class="meta">Matte finish, insulated</div>
                </div>
                <div class="price">$34</div>
              </div>

              <div class="variant-dots" role="list" aria-label="Color options">
                <button class="dot" title="Sea Blue" style="background:#06b6d4; border-color:transparent" data-color="#06b6d4" aria-label="Choose Sea Blue"></button>
                <button class="dot" title="Midnight" style="background:#083344; border-color:transparent" data-color="#083344" aria-label="Choose Midnight"></button>
                <button class="dot" title="Pearl" style="background:#ffffff; border-color:rgba(6,182,212,0.18)" data-color="#ffffff" aria-label="Choose Pearl"></button>
              </div>

              <div class="add-row">
                <button class="btn add-to-cart" data-name="Classic Ocean — 20oz" data-price="34">Add to Cart</button>
                <button class="ghost" aria-label="Quick view">Quick view</button>
              </div>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="card reveal">
            <div class="bottle-illustration">
              <!-- SVG Bottle Green -->
              <svg class="bottle-svg" viewBox="0 0 80 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs><linearGradient id="b2" x1="0" x2="1"><stop offset="0" stop-color="#e9fffb"/><stop offset="1" stop-color="#bffcf5"/></linearGradient></defs>
                <rect x="20" y="20" width="40" height="120" rx="14" fill="url(#b2)" stroke="#06b6d4" stroke-width="3"/>
                <rect x="26" y="2" width="28" height="24" rx="8" fill="#0ea5a4"/>
                <circle cx="40" cy="80" r="5" fill="#0ea5a4"/>
              </svg>
            </div>
            <div class="card-info">
              <div style="display:flex; align-items:center; justify-content:space-between;">
                <div>
                  <div class="name">Insulate Pro — 32oz</div>
                  <div class="meta">For long days &amp; trips</div>
                </div>
                <div class="price">$42</div>
              </div>

              <div class="variant-dots">
                <button class="dot" style="background:#0ea5a4;border-color:transparent" data-color="#0ea5a4" aria-label="Choose Mint"></button>
                <button class="dot" style="background:#0b7285;border-color:transparent" data-color="#0b7285" aria-label="Choose Teal"></button>
                <button class="dot" style="background:#ffd6a5;border-color:transparent" data-color="#ffd6a5" aria-label="Choose Sand"></button>
              </div>

              <div class="add-row">
                <button class="btn add-to-cart" data-name="Insulate Pro — 32oz" data-price="42">Add to Cart</button>
                <button class="ghost" aria-label="Quick view">Quick view</button>
              </div>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="card reveal">
            <div class="bottle-illustration">
              <!-- SVG Bottle Limited -->
              <svg class="bottle-svg" viewBox="0 0 80 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
